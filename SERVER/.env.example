PORT=5000

DB_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=indianet

JWT_SECRET=change-this-to-a-long-random-string

CLIENT_URL=https://indianet.equvinoxis.com
CORS_ORIGINS=https://indianet.equvinoxis.com
SUPPORT_EMAIL=team@equvinoxis.com

# Email — Gmail API (recommended for Railway; see SERVER/GMAIL_OAUTH_SETUP.md)
MAIL_PROVIDER=gmail
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret
GMAIL_REFRESH_TOKEN=1//your-refresh-token
GMAIL_USER=info@equvinoxis.com
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
MAIL_FROM=Indianet <info@equvinoxis.com>

# Optional fallbacks (not needed if Gmail API is configured)
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_USER=info@equvinoxis.com
# MAIL_PASS=your-google-app-password

ADMIN_MAIL=team@equvinoxis.com
ADMIN_EMAIL=team@equvinoxis.com
ADMIN_PASSWORD=change-me-strong-password

# Razorpay (online payments at checkout)
RAZORPAY_ID=rzp_live_xxxxxxxx
RAZORPAY_SECREt=your_razorpay_secret

# ShipRocket (shipping rates, labels, tracking)
SHIPROCKET_EMAIL=your@shiprocket.in
SHIPROCKET_PASS=your_shiprocket_password

# WhatsApp order alerts (pick one provider)
# Twilio WhatsApp:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Or generic WhatsApp API webhook:
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_S3_BUCKET=indianet-equvinoxis
S3_PUBLIC_URL=https://indianet-equvinoxis.s3.eu-north-1.amazonaws.com
